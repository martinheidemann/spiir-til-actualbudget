# ---------------------------------------------------------------
# Kopier denne fil til ".env" og udfyld dine værdier.
# .env filen deles IKKE med andre — den indeholder dit password.
# ---------------------------------------------------------------

# Actual Budget Desktop App (Windows/Mac/Linux — ingen server nødvendig):
ACTUAL_SERVER_URL=http://localhost:5006

# Selvhostet server — erstat med din URL:
# ACTUAL_SERVER_URL=https://budget.eksempel.dk

# Password du satte da du oprettede/startede Actual Budget:
ACTUAL_PASSWORD=dit-password-her
